# GitHub personal access token
# Create one at: https://github.com/settings/tokens
# Needs:
#   - repo     (full control) for creating issues and reading PRs
#   - project  for adding issues to the project board and setting fields
#              (Area / Size / Priority / Requester / Feature / Release / Serverless-pub).
#              Without it, issues are still created but board fields are skipped.
# With the gh CLI:  gh auth refresh -s project
GITHUB_TOKEN=ghp_...

# Port for the review UI (default: 3847)
PORT=3847
